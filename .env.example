# Copy this file to `.env` and fill in your own values. `.env` is gitignored.
#
# Google Maps SDK key — used by react-native-maps (the embedded/​full-screen map)
# and injected into the native build + Constants.expoConfig.extra by app.config.js.
# Get one at https://console.cloud.google.com/ and RESTRICT it (Android package
# name + SHA-1 fingerprint, and only the Maps SDKs you use) before shipping.
GOOGLE_MAPS_API_KEY=
